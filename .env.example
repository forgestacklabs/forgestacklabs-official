# Create a Notion internal integration at notion.so/my-integrations and use its secret here.
# Share that integration with both the Revenue and Cash Position databases via Notion > ... > Connections.
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_REVENUE_DATABASE_ID=
NOTION_CASH_POSITION_DATABASE_ID=
CERT_NOTION_DATABASE_ID=
EMPLOYEE_NOTION_DATABASE_ID=
FORGEOS_PROJECTS_NOTION_DATABASE_ID=
FORGEOS_TASKS_NOTION_DATABASE_ID=
FORGEOS_EXPENSES_NOTION_DATABASE_ID=
FORGEOS_DOCUMENTS_NOTION_DATABASE_ID=
FORGEOS_MEETINGS_NOTION_DATABASE_ID=
FORGEOS_NOTIFICATIONS_NOTION_DATABASE_ID=
FORGEOS_CRM_NOTION_DATABASE_ID=
FORGEOS_BLOCKED_DATES_NOTION_DATABASE_ID=

# Format: email|password|role|name. Roles: CEO, CTO, COO, Employee.
ADMIN_USERS=admin@example.com|plain-password|CEO|Admin Name

# Random secret used to sign the httpOnly admin session cookie.
ADMIN_SESSION_SECRET=